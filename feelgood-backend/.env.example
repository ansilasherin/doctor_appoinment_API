# Copy this to .env and fill in values
DATABASE_URL=postgresql://user:password@localhost:5432/feelgood_db
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP Email (use Gmail App Password or Brevo free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your@gmail.com
EMAIL_FROM_NAME=FeelGood Appointments

# CORS - comma separated frontend URLs
CORS_ORIGINS=http://localhost:3000,https://feelgood-appointments.lovable.app

# App
APP_ENV=development
APP_NAME=FeelGood Appointments API
